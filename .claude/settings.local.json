{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(mkdir:*)",
      "Bash(flutter analyze:*)",
      "Bash(flutter test:*)",
      "Bash(flutter pub:*)",
      "Bash(mv:*)",
      "Bash(rm:*)",
      "Bash(flutter build:*)",
      "Bash(flutter run:*)",
      "mcp__ide__getDiagnostics"
    ],
    "deny": [],
    "defaultMode": "acceptEdits"
  }
}